# ─── 이 저장소에 이미 맞춰 둔 값 (firebase-applet-config.json · deploy.yml 기준) ───
# 실제 배포·로컬 작업용은 이 파일을 복사해 `.env` 로 쓰고, 비밀 값만 본인 환경에서 채우세요.
# `.env` 는 git 에 올리지 마세요.

# GEMINI (코드에서 쓰는 경우에만). 키는 Google AI Studio 에서 발급.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# 공식 사이트 canonical (index.html 과 동일)
APP_URL="https://xn--vk1b88f7uf0b7kda.com"

# ─── Vite (루트 .env) — 선택: Firebase Web API 키(공개 키, 번들과 동일 소스) ───
VITE_FIREBASE_API_KEY="AIzaSyDHdqrSUeoTlBTL_AgDC1snFxc_LTIc9Hs"

# ─── 거래명세서 이메일 발송 (Gmail SMTP 또는 한메일/다음 SMTP) ───────────
# 코드·관리자에 쓰인 계정과 맞추려면 아래 사용자명 사용 (비밀번호는 앱 비밀번호로 Vercel·로컬에만)
GMAIL_USER="phajuquick37@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ─── Firebase (Vercel 서버리스 /api/tax-run 등에서 덮어쓸 때, 웹 설정과 동일하게) ───
FIREBASE_WEB_API_KEY="AIzaSyDHdqrSUeoTlBTL_AgDC1snFxc_LTIc9Hs"
FIREBASE_PROJECT_ID="gen-lang-client-0127550748"
FIREBASE_STORAGE_BUCKET="gen-lang-client-0127550748.firebasestorage.app"
FIRESTORE_DATABASE_ID="ai-studio-08ae3b29-6eb5-4e08-8bb0-f20ab80e5ffc"

# ─── 세금계산서 자동수집 (tax-invoice-automation / Cloud Run) ───────────
# 상세·추가 변수: tax-invoice-automation/.env.example
# IMAP: TAX_* 가 비어 있으면 일부 코드 경로에서 GMAIL_* 과 동일 계정을 씁니다.
TAX_IMAP_EMAIL="phajuquick37@gmail.com"
TAX_IMAP_APP_PASSWORD="xxxx xxxx xxxx xxxx"
# 로컬: 서비스 계정 JSON 절대 경로 또는 봇 폴더 기준 상대 경로 (저장소에 비밀 키 파일 커밋 금지)
TAX_GOOGLE_CREDENTIALS_PATH="./tax-invoice-automation/google_credentials.json"
# GOOGLE_APPLICATION_CREDENTIALS="./tax-invoice-automation/google_credentials.json"
TAX_EMAIL_DAYS_LIMIT=365
# Daum 한메일만 쓸 때는 보통 INBOX. Gmail 전체함: INBOX,[Gmail]/All Mail
TAX_IMAP_FOLDERS=INBOX
# Cloud Run·Vercel /api/tax-run 과 동일한 임의 긴 문자열 (GitHub Secret: TAX_COLLECT_SECRET)
TAX_COLLECT_SECRET=""

# ─── 로컬 npm run dev → 프로덕션 Vercel API 로 우회할 때 (배포 URL로 교정) ───
# VITE_DEV_VERCEL_API="https://(Vercel 프로젝트).vercel.app"

# ─── 메인이 Firebase Hosting 등이면 /api 를 Vercel 절대 경로로 ───
# VITE_VERCEL_API_ORIGIN="https://(Vercel 프로젝트).vercel.app"

# ─── 관리자「지금 수집」: Vercel /api/tax-run → Cloud Run ───
# 서비스명 tax-automation · 리전 asia-northeast3 (deploy.yml). 정확한 베이스 URL은
# GCP Cloud Run 콘솔 또는 GitHub Actions「Cloud Run 배포 주소 확인」Summary 의 status.url.
# VITE_TAX_AUTOMATION_URL="https://tax-automation-….asia-northeast3.run.app"
# TAX_AUTOMATION_URL="https://tax-automation-….asia-northeast3.run.app"
# Vercel·클라이언트용 시크릿( Cloud Run TAX_COLLECT_SECRET 과 동일)
# VITE_TAX_AUTOMATION_SECRET=""
# TAX_AUTOMATION_SECRET=""
# 하위 호환
# VITE_TAX_COLLECT_SECRET=""
