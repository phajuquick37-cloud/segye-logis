# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ─── 거래명세서 이메일 발송 (Gmail SMTP 또는 한메일/다음 SMTP) ───────────
# 1) Gmail: 2단계 인증 → 앱 비밀번호 (16자리, GMAIL_APP_PASSWORD 에 붙여넣기, 공백은 코드에서 제거)
# 2) @hanmail.net / @daum.net: Daum→메일→환경설정→보안→[앱 비밀번호] 등, 동일한 이름의 환경 변수 사용
#    API(sendMail)는 주소에 따라 smtp.daum.net(465) / Gmail service 자동 선택
# Vercel: Dashboard → Project → Settings → Environment Variables
#   Production(및 Preview 필요 시)에 GMAIL_USER, GMAIL_APP_PASSWORD 등록 후 재배포
GMAIL_USER="your-gmail@gmail.com"
# 또는 your-id@hanmail.net
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ─── 세금계산서 자동수집 (tax-invoice-automation / Cloud Run) ───────────
# 상세·추가 변수는 tax-invoice-automation/.env.example 참고.
# IMAP: 아래를 넣으면 TAX_* 가 없을 때 GMAIL_* 과 동일하게 쓰입니다.
# TAX_IMAP_EMAIL=
# TAX_IMAP_APP_PASSWORD=
# TAX_GOOGLE_CREDENTIALS_PATH=/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# TAX_EMAIL_DAYS_LIMIT=365
# TAX_IMAP_FOLDERS=INBOX,[Gmail]/All Mail
# TAX_COLLECT_SECRET=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIRESTORE_DATABASE_ID=

# ─── 관리자(Admin)에서 세금계산서 수집 API 호출 (Vite 프론트) ─────────────
# Cloud Run tax-automation 서비스 URL (슬래시 없이)
# VITE_TAX_AUTOMATION_URL="https://tax-automation-xxxxx-xx.a.run.app"
# GitHub Secret TAX_COLLECT_SECRET / Cloud Run TAX_COLLECT_SECRET 과 동일 값
# VITE_TAX_AUTOMATION_SECRET="your-secret"
