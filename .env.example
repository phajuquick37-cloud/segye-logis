# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ─── 거래명세서 이메일 발송 (Gmail SMTP 또는 한메일/다음 SMTP) ───────────
# 1) Gmail: 2단계 인증 → 앱 비밀번호 (16자리, GMAIL_APP_PASSWORD 에 붙여넣기, 공백은 코드에서 제거)
# 2) @hanmail.net / @daum.net: Daum→메일→환경설정→보안→[앱 비밀번호] 등, 동일한 이름의 환경 변수 사용
#    API(sendMail)는 주소에 따라 smtp.daum.net(465) / Gmail service 자동 선택
# Vercel: Dashboard → Project → Settings → Environment Variables
#   Production(및 Preview 필요 시)에 GMAIL_USER, GMAIL_APP_PASSWORD 등록 후 재배포
GMAIL_USER="your-gmail@gmail.com"
# 또는 your-id@hanmail.net
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ─── 세금계산서 자동수집 (tax-invoice-automation / Cloud Run) ───────────
# 상세·추가 변수는 tax-invoice-automation/.env.example 참고.
# IMAP: 아래를 넣으면 TAX_* 가 없을 때 GMAIL_* 과 동일하게 쓰입니다.
# TAX_IMAP_EMAIL=
# TAX_IMAP_APP_PASSWORD=
# TAX_GOOGLE_CREDENTIALS_PATH=/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# TAX_EMAIL_DAYS_LIMIT=365
# TAX_IMAP_FOLDERS=INBOX,[Gmail]/All Mail
# TAX_COLLECT_SECRET=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIRESTORE_DATABASE_ID=

# (선택) /api/tax-run — 기본은 코드 내 공개 키와 동일. 덮어쓰려면:
# FIREBASE_WEB_API_KEY="웹 API 키"
#
# (선택) 로컬 npm run dev 만 쓸 때 Production Vercel로 /api/tax-run 를 넘김 — 본인 배포 URL로 설정
# VITE_DEV_VERCEL_API="https://프로젝트명.vercel.app"
#
# (선택) 메인 도메인이 Firebase Hosting일 때만: /api/sendMail·/api/tax-run 는 Vercel 서버리스에 남김
# GitHub Actions 배포 시 Secrets VITE_VERCEL_API_ORIGIN 과 동일 값
# VITE_VERCEL_API_ORIGIN="https://프로젝트명.vercel.app"
#
# ─── 관리자(Admin)에서 세금계산서 수집: Vercel 서버 /api/tax-run 이 Cloud Run으로 프록시 (CORS 없음) ─
# Vercel Production(및 Preview)에 아래를 넣고 재배포. (TAX_ 접두: 서버만, 프론트에 노출 안 됨)
# TAX_AUTOMATION_URL="https://tax-automation-xxxxx-xx.a.run.app"
# TAX_AUTOMATION_SECRET="GitHub TAX_COLLECT_SECRET 과 동일(선택)"
# 하위 호환: TAX_ 미설정 시 VITE_TAX_AUTOMATION_URL / VITE_TAX_AUTOMATION_SECRET 을 읽음
# VITE_TAX_AUTOMATION_URL="https://tax-automation-xxxxx-xx.a.run.app"
# VITE_TAX_AUTOMATION_SECRET="your-secret"
