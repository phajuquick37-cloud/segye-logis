# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ─── 거래명세서 이메일 발송 (Gmail SMTP) ───────────────────────────────
# 1. Google 계정 → 보안 → 2단계 인증 활성화
# 2. Google 계정 → 보안 → 앱 비밀번호 생성 (앱: 메일, 기기: 기타)
# 3. 생성된 16자리 비밀번호를 GMAIL_APP_PASSWORD 에 입력
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ─── 관리자(Admin)에서 세금계산서 수집 API 호출 (Vite 프론트) ─────────────
# Cloud Run tax-automation 서비스 URL (슬래시 없이)
# VITE_TAX_AUTOMATION_URL="https://tax-automation-xxxxx-xx.a.run.app"
# GitHub Secret TAX_COLLECT_SECRET / Cloud Run TAX_COLLECT_SECRET 과 동일 값
# VITE_TAX_AUTOMATION_SECRET="your-secret"

# ─── 세금계산서 IMAP (Cloud Run tax-automation 컨테이너) ─────────────────
# 메일 조회 기간(일). 기본 365. 부하가 크면 90~180 등으로 낮춤.
# TAX_EMAIL_DAYS_LIMIT=365
