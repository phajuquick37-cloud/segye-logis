# tax-invoice-automation — 로컬/도커 실행 시 참고 (이 파일을 .env 로 복사하지 말고,
# Windows는 set / PowerShell $env:, Linux는 export, Cloud Run은 콘솔·시크릿으로 설정)

# ─── 필수: Gmail IMAP ─────────────────────────────────────────────
TAX_IMAP_EMAIL=your-mail@gmail.com
TAX_IMAP_APP_PASSWORD=xxxxxxxxxxxxxxxx
# 또는 프론트와 동일 이름:
# GMAIL_USER=your-mail@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# ─── 선택: IMAP ───────────────────────────────────────────────────
# TAX_IMAP_SERVER=imap.gmail.com
# TAX_IMAP_PORT=993
# 쉼표로 구분 (한글 Gmail은 [Gmail]/모든 메일 등으로 조정)
# TAX_IMAP_FOLDERS=INBOX,[Gmail]/All Mail

# ─── 필수에 가깝다: Firebase 서비스 계정 JSON 경로 ─────────────────
# 로컬: 프로젝트 내 google_credentials.json 또는 절대 경로
TAX_GOOGLE_CREDENTIALS_PATH=./google_credentials.json
# 표준 변수 (동일 의미)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ─── 선택: Firebase / Firestore (기본값은 기존 프로젝트) ─────────────
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIRESTORE_DATABASE_ID=

# ─── 선택: 사업자·회사 표기 (조회 화면용) ──────────────────────────
# TAX_BUSINESS_NUMBER=1234567890
# TAX_BUSINESS_NUMBER_FORMATTED=123-45-67890
# TAX_COMPANY_NAME=
# TAX_REPRESENTATIVE=

# ─── 선택: Google Sheets 백업 ───────────────────────────────────────
# TAX_SHEETS_ENABLED=true
# TAX_SHEETS_SPREADSHEET_ID=
# TAX_SHEETS_CREDENTIALS_PATH=
# TAX_SHEETS_SHEET_NAME=세금계산서

# ─── 선택: 수집·OCR ───────────────────────────────────────────────
# TAX_EMAIL_DAYS_LIMIT=365
# TAX_OUTPUT_DIR=output
# TAX_OCR_ENABLED=true
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# ─── API 서버 (api_server.py) ───────────────────────────────────────
# TAX_COLLECT_SECRET=임의의-긴-문자열
