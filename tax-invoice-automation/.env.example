# tax-invoice-automation — 로컬/도커 실행 시 참고 (이 파일을 .env 로 복사하지 말고,
# Windows는 set / PowerShell $env:, Linux는 export, Cloud Run은 콘솔·시크릿으로 설정)

# ─── 필수: 메일함 IMAP (Gmail 또는 Daum 한메일) ─────────────────────
TAX_IMAP_EMAIL=your-mail@gmail.com
TAX_IMAP_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Daum(한메일) 예: TAX_IMAP_EMAIL=id@daum.net → 서버 미지정 시 자동 imap.daum.net
# 또는 프론트와 동일 이름:
# GMAIL_USER=your-mail@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# ─── 선택: IMAP ───────────────────────────────────────────────────
# TAX_IMAP_SERVER=imap.gmail.com   # Daum은 보통 생략(자동), 아니면 imap.daum.net
# TAX_IMAP_PORT=993
# 쉼표로 구분. Gmail: INBOX,[Gmail]/All Mail  /  Daum: 기본 INBOX만
# TAX_IMAP_FOLDERS=INBOX,[Gmail]/All Mail
# 수집 시작(수신일·IMAP SINCE) 기본: 2026-04-10 이후. 옛 메일 전체: TAX_EMAIL_SINCE_MIN=
# TAX_EMAIL_SINCE_MIN=2026-04-10
# 자동 수집 주기(분, 기본 60)
# TAX_SCHEDULE_INTERVAL_MINUTES=60
# 실제 메일 "발신자" 주소에 포함되면 수집(콤마 구분, 소문자로 넣으면 됨)
# TAX_EXTRA_SENDER_ALLOWLIST=noreply@real-carrier.co.kr,service@tax22.co.kr
# 기본 True: 제목이 세계로지스 수취 안내만 통과 (~님께/귀하…발행…세금계산서). 예전 방식은 false
# TAX_INVOICE_SUBJECT_STRICT=true
# 매 시 정각에 가깝게 자동 수집(분). Cloud Run은 min-instances=1 권장
# TAX_SCHEDULE_INTERVAL_MINUTES=60
# IMAP은 (KST 오늘 − N일)부터 검색, TAX_EMAIL_SINCE_MIN 과 큰 쪽을 바닥으로
# TAX_MAIL_LOOKBACK_DAYS=30
# Firestore 저장: OCR 추출 발행일이 KST 오늘 이상일 때만 (과거 전표 제외)
# TAX_INVOICE_ISSUE_FROM_TODAY_ONLY=true

# ─── 필수에 가깝다: Firebase 서비스 계정 JSON 경로 ─────────────────
# 로컬: 프로젝트 내 google_credentials.json 또는 절대 경로
TAX_GOOGLE_CREDENTIALS_PATH=./google_credentials.json
# 표준 변수 (동일 의미)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ─── 선택: Firebase / Firestore (기본값은 기존 프로젝트) ─────────────
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIRESTORE_DATABASE_ID=

# ─── 선택: 사업자·회사 표기 (조회 화면용) ──────────────────────────
# TAX_BUSINESS_NUMBER=1234567890
# TAX_BUSINESS_NUMBER_FORMATTED=123-45-67890
# TAX_COMPANY_NAME=
# TAX_REPRESENTATIVE=

# ─── 선택: Google Sheets 백업 ───────────────────────────────────────
# TAX_SHEETS_ENABLED=true
# TAX_SHEETS_SPREADSHEET_ID=
# TAX_SHEETS_CREDENTIALS_PATH=
# TAX_SHEETS_SHEET_NAME=세금계산서

# ─── 선택: 수집·OCR ───────────────────────────────────────────────
# TAX_EMAIL_DAYS_LIMIT=365
# TAX_OUTPUT_DIR=output
# TAX_OCR_ENABLED=true
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# ─── API 서버 (api_server.py) ───────────────────────────────────────
# TAX_COLLECT_SECRET=임의의-긴-문자열
